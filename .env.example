KIMI_API_KEY=your_moonshot_api_key_here
PORT=3000
RUST_LOG=wc2026_sim=info
# Background live-data refresh interval in minutes (0 disables it)
LIVE_REFRESH_MINUTES=30
# Strength-model blend weights "elo,dc,pi" (1,0,0 = pure Elo)
ENSEMBLE_WEIGHTS=0.5,0.3,0.2
# Set to 1 ONLY behind a sanitizing reverse proxy (e.g. Railway) so rate
# limiting keys on the proxy-appended X-Forwarded-For client IP. Off by
# default: a spoofed header would bypass rate limits on direct connections.
TRUST_PROXY=0
